{
  "name": "automation-exercise-e2e",
  "version": "1.0.0",
  "description": "E2E test framework for automationexercise.com using CodeceptJS + Playwright",
  "main": "codecept.conf.js",
  "scripts": {
    "e2e": "node scripts/run-e2e.js",
    "e2e:parallel": "node scripts/run-e2e-parallel.js",
    "e2e:dry-run": "codeceptjs dry-run --features --steps",
    "e2e:a11y": "PROFILE=local:@accessibility:chromeHeadless:playwright node scripts/run-e2e.js",
    "e2e:wcag": "PROFILE=local:@wcag22aa:chromeHeadless:playwright node scripts/run-e2e.js",
    "e2e:eaa": "PROFILE=local:@eaa:chromeHeadless:playwright node scripts/run-e2e.js",
    "e2e:ada": "PROFILE=local:@ada:chromeHeadless:playwright node scripts/run-e2e.js",
    "allure:generate": "allure generate ./output/allure-results -o ./allure-report --clean",
    "allure:open": "allure open ./allure-report",
    "allure:serve": "allure serve ./output/allure-results",
    "allure:report": "allure generate ./output/allure-results -o ./allure-report --clean && allure open ./allure-report",
    "clean": "rm -rf output allure-report",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix"
  },
  "keywords": [
    "e2e",
    "codeceptjs",
    "playwright",
    "automation",
    "testing"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@axe-core/playwright": "^4.10.1",
    "axios": "^1.7.2",
    "codeceptjs": "^3.7.5",
    "codeceptjs-chai": "^1.0.1",
    "allure-codeceptjs": "^3.0.0",
    "playwright": "^1.56.1",
    "allure-commandline": "^2.30.0",
    "form-data": "^4.0.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-codeceptjs": "^1.3.0",
    "prettier": "^3.3.2"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@9.1.0"
}
