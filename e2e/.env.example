# Environment Configuration
# Environment name: local, staging, production (URLs configured in e2e/config/aggregate.js)
ENVIRONMENT=local

# Browser Configuration
BROWSER=chromeHeadless
HEADLESS=true

# Test Configuration
DEFAULT_TIMEOUT=30000
RETRY_COUNT=1

# Parallel Execution
WORKERS=4

# AI Provider Configuration (for @playwrightMCP tests with AI analysis)
# Options: ollama (default, free), perplexity (paid), groq (free tier)
AI_PROVIDER=ollama

# Ollama Configuration (FREE - runs locally)
# Install: https://ollama.ai/download
# Start: ollama serve
# Pull model: ollama pull llama3.2
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=llama3.2

# Perplexity API Key (PAID - optional)
# Get your API key from: https://www.perplexity.ai/settings/api
# PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Groq API Key (FREE tier available - optional)
# Get your API key from: https://console.groq.com/keys
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# Mailgun Configuration (Email Testing)
# ============================================
# Sign up at: https://signup.mailgun.com/new/signup
# Free tier includes sandbox domain for testing

# Your Mailgun Private API Key
# Find at: Mailgun Dashboard → API Keys → Private API Key
# MAILGUN_API_KEY=your-private-api-key-here

# Your Mailgun Domain (sandbox or custom)
# Find at: Mailgun Dashboard → Sending → Domains
# Example sandbox: sandbox1234567890abcdef.mailgun.org
# MAILGUN_DOMAIN=sandbox1234567890abcdef.mailgun.org

# From email address (optional, defaults to test@{domain})
# MAILGUN_FROM_EMAIL=test@sandbox1234567890abcdef.mailgun.org

# Mock mode - set to 'true' to test without real Mailgun credentials
# Useful for CI/CD or demo purposes
MAILGUN_MOCK_MODE=true

# ============================================
# GitHub Secrets (CI/CD)
# ============================================
# Configure the following in:
# GitHub Repository → Settings → Secrets and Variables → Actions → New repository secret
#
# Secret name | Purpose
# -------------------------|------------------------------------------------------------
# MAILGUN_API_KEY | Mailgun Private API Key (general API operations/retrieval)
# MAILGUN_SENDING_API_KEY | Mailgun Sending API Key — mapped to MAILGUN_API_KEY in tests
# | when running in CI (send-only key with fewer privileges)
# MAILGUN_DOMAIN | Mailgun domain, e.g. sandbox1234567890abcdef.mailgun.org
# MAILGUN_FROM_EMAIL | Sender address (optional, defaults to test@{MAILGUN_DOMAIN})
#
# Note: MAILGUN_MOCK_MODE is automatically set to 'false' in CI when
# MAILGUN_SENDING_API_KEY is present, and 'true' when it is absent.
# PR check workflows always force MAILGUN_MOCK_MODE=true for safety.

